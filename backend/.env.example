PORT=4000

# ── SQL Server connection ────────────────────────────────────────
# Same as the "Server name" you type in SSMS (e.g. localhost or localhost\SQLEXPRESS)
DB_SERVER=localhost
# Uncomment only if your SSMS server name includes a named instance
# DB_INSTANCE=SQLEXPRESS
# DB_PORT=1433
DB_NAME=gbhss

# ── Authentication mode ─────────────────────────────────────────
# Option A — Windows Integrated Auth (recommended for local dev on Windows)
DB_TRUSTED_CONNECTION=true
DB_ODBC_DRIVER=ODBC Driver 17 for SQL Server
DB_USER=
DB_PASSWORD=

# Option B — SQL Server login (set DB_TRUSTED_CONNECTION=false and fill below)
# DB_TRUSTED_CONNECTION=false
# DB_USER=sa
# DB_PASSWORD=yourStrongPassword!

DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# ── JWT ─────────────────────────────────────────────────────────
# CHANGE THIS to a long random string in production!
# Generate one with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h
